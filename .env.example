# Offline Pentesting AI - Environment Configuration
# Copy this file to .env and update values as needed

# ============================================================================
# DEBUG & LOGGING
# ============================================================================

# Enable debug mode (True/False)
DEBUG=False

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# API SERVER
# ============================================================================

# API host (0.0.0.0 to listen on all interfaces)
API_HOST=0.0.0.0

# API port
API_PORT=8000

# ============================================================================
# OLLAMA LLM CONFIGURATION
# ============================================================================

# Ollama base URL
OLLAMA_BASE_URL=http://localhost:11434

# LLM model to use (mistral, llama2, neural-chat, orca-mini, etc.)
OLLAMA_MODEL=mistral

# Embeddings model for vector searches
EMBEDDINGS_MODEL=nomic-embed-text

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite database URL (recommended for most use cases)
# For other databases: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./database/sqlite/app.db

# Vector database type: chroma, pinecone, faiss, weaviate
VECTOR_DB_TYPE=chroma

# Vector database connection string (if using remote service)
# VECTOR_DB_URL=https://your-vector-db.example.com

# ============================================================================
# SECURITY
# ============================================================================

# Secret key for session management and encryption
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-me

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Enable HTTPS (for production)
ENABLE_HTTPS=False

# SSL certificate path (if HTTPS enabled)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# ============================================================================
# REPORTING
# ============================================================================

# Report formats to generate (comma-separated): html, pdf, json
REPORT_FORMAT=html,pdf,json

# Include evidence in reports (True/False)
REPORT_INCLUDE_EVIDENCE=true

# Report output directory
REPORT_OUTPUT_DIR=./reports

# ============================================================================
# SECURITY TOOLS CONFIGURATION
# ============================================================================

# Default nmap arguments (space-separated)
NMAP_DEFAULT_ARGS=-sV -sC

# Default scan timeout (seconds)
SCAN_TIMEOUT=300

# Maximum concurrent scans
MAX_CONCURRENT_SCANS=5

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# Cache type: memory, redis, disk
CACHE_TYPE=memory

# Redis URL (if CACHE_TYPE=redis)
# REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds
CACHE_TTL=3600

# ============================================================================
# AI REASONING ENGINE
# ============================================================================

# Temperature for AI responses (0.0-1.0, higher = more creative)
AI_TEMPERATURE=0.7

# Maximum tokens per response
AI_MAX_TOKENS=2048

# Model context window size
AI_CONTEXT_WINDOW=4096

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# GUI theme: dark, light (dark/red is default)
GUI_THEME=dark

# Font size (points)
GUI_FONT_SIZE=11

# Window size: WIDTHxHEIGHT
GUI_WINDOW_SIZE=1600x900

# ============================================================================
# PLUGIN CONFIGURATION
# ============================================================================

# Enable plugin system (True/False)
ENABLE_PLUGINS=True

# Plugin directory path
PLUGIN_DIR=./plugins

# Auto-load plugins on startup
AUTO_LOAD_PLUGINS=True

# ============================================================================
# EXPERIMENTAL FEATURES
# ============================================================================

# Enable WebSocket support for real-time updates
ENABLE_WEBSOCKET=True

# Enable collaboration features
ENABLE_COLLABORATION=False

# Enable GPU acceleration (if available)
ENABLE_GPU=False

# ============================================================================
# MISCELLANEOUS
# ============================================================================

# Application name
APP_NAME=Offline Pentesting AI

# Application version (read from code)
# APP_VERSION=1.0.0

# Environment: development, staging, production
ENVIRONMENT=development

# Analytics enabled (True/False)
ENABLE_ANALYTICS=False

# Check for updates on startup
CHECK_FOR_UPDATES=False

# ============================================================================
# NOTES
# ============================================================================
# - Make sure to change SECRET_KEY in production environments
# - For Ollama models list, run: ollama list
# - For detailed configuration, see docs/CONFIGURATION.md
# - Never commit actual .env file with sensitive values
# ============================================================================
